---
import Layout from "../layouts/Layout.astro";

const features = [
  {
    title: "Control en tiempo real",
    text: "Monitorea el inventario de manera inmediata y mantén el stock siempre actualizado.",
    icon: "📦",
  },
  {
    title: "Alertas automáticas",
    text: "Detecta productos con stock bajo y evita quiebres de inventario en el negocio.",
    icon: "⚠️",
  },
  {
    title: "Reportes inteligentes",
    text: "Obtén información clara para mejorar decisiones de compra, reposición y control.",
    icon: "📊",
  },
  {
    title: "Acceso seguro",
    text: "Administra usuarios, roles y permisos dentro del sistema.",
    icon: "🔒",
  },
];

const modules = [
  {
    name: "Gestión de productos",
    icon: "🗂️",
    desc: "Registro, edición y consulta de productos dentro del almacén.",
  },
  {
    name: "Entradas y salidas",
    icon: "🔄",
    desc: "Control detallado de ingresos y movimientos de mercancía.",
  },
  {
    name: "Control de stock",
    icon: "📉",
    desc: "Visualización del stock actual y alertas por niveles mínimos.",
  },
  {
    name: "Usuarios y roles",
    icon: "👥",
    desc: "Administración de accesos para responsables y trabajadores.",
  },
];

const stats = [
  { label: "Productos registrados", value: "1,250" },
  { label: "Movimientos del día", value: "86" },
  { label: "Alertas activas", value: "12" },
  { label: "Reportes generados", value: "48" },
];

const reports = [
  "Reporte de stock actual",
  "Historial de entradas y salidas",
  "Productos con stock bajo",
  "Resumen de movimientos por fecha",
];
---

<Layout title="SmartStock | Sistema inteligente de gestión de almacén">
  <main class="min-h-screen overflow-x-hidden bg-slate-950 text-white">
    <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
      <div class="absolute left-[-120px] top-[-80px] h-72 w-72 rounded-full bg-cyan-500/20 blur-3xl"></div>
      <div class="absolute right-[-80px] top-[120px] h-80 w-80 rounded-full bg-blue-500/15 blur-3xl"></div>
      <div class="absolute bottom-[-100px] left-[30%] h-72 w-72 rounded-full bg-violet-500/10 blur-3xl"></div>
    </div>

    <header class="sticky top-0 z-50 border-b border-white/10 bg-slate-950/75 backdrop-blur-xl">
      <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
        <a href="#inicio" class="text-2xl font-black tracking-tight">
          Smart<span class="text-cyan-400">Stock</span>
        </a>

        <div class="hidden items-center gap-8 text-sm text-slate-300 md:flex">
          <a href="#inicio" class="relative transition hover:text-cyan-400 after:absolute after:left-0 after:-bottom-1 after:h-[2px] after:w-0 after:bg-cyan-400 after:transition-all after:duration-300 hover:after:w-full">Inicio</a>
          <a href="#funciones" class="relative transition hover:text-cyan-400 after:absolute after:left-0 after:-bottom-1 after:h-[2px] after:w-0 after:bg-cyan-400 after:transition-all after:duration-300 hover:after:w-full">Funciones</a>
          <a href="#modulos" class="relative transition hover:text-cyan-400 after:absolute after:left-0 after:-bottom-1 after:h-[2px] after:w-0 after:bg-cyan-400 after:transition-all after:duration-300 hover:after:w-full">Módulos</a>
          <a href="#reportes" class="relative transition hover:text-cyan-400 after:absolute after:left-0 after:-bottom-1 after:h-[2px] after:w-0 after:bg-cyan-400 after:transition-all after:duration-300 hover:after:w-full">Reportes</a>
          <a href="#contacto" class="relative transition hover:text-cyan-400 after:absolute after:left-0 after:-bottom-1 after:h-[2px] after:w-0 after:bg-cyan-400 after:transition-all after:duration-300 hover:after:w-full">Contacto</a>
        </div>

        <div class="flex items-center gap-3">
          <button class="hidden rounded-full border border-white/15 px-4 py-2 text-sm text-slate-200 transition hover:border-cyan-400 hover:text-cyan-400 sm:block">
            Iniciar sesión
          </button>
          <button class="rounded-full bg-cyan-400 px-4 py-2 text-sm font-semibold text-slate-950 shadow-lg shadow-cyan-500/20 transition duration-300 hover:scale-105 hover:bg-cyan-300">
            Ver demo
          </button>
        </div>
      </nav>
    </header>

    <section
      id="inicio"
      class="mx-auto grid max-w-7xl gap-14 px-6 py-20 md:grid-cols-2 md:items-center md:py-28"
    >
      <div class="slide-left">
        <span class="inline-flex rounded-full border border-cyan-400/30 bg-cyan-400/10 px-4 py-1 text-sm text-cyan-300">
          Software empresarial moderno
        </span>

        <h1 class="mt-6 max-w-3xl text-5xl font-black leading-tight md:text-6xl">
          Sistema inteligente de
          <span class="bg-gradient-to-r from-cyan-400 to-blue-400 bg-clip-text text-transparent">
            gestión de almacén
          </span>
          para negocios
        </h1>

        <p class="mt-6 max-w-xl text-lg leading-8 text-slate-300">
          Controla inventario, registra entradas y salidas, visualiza alertas
          y genera reportes con una plataforma moderna conectada a base de datos.
        </p>

        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="#modulos"
            class="rounded-full bg-cyan-400 px-6 py-3 font-semibold text-slate-950 shadow-lg shadow-cyan-500/20 transition duration-300 hover:scale-105 hover:bg-cyan-300"
          >
            Explorar módulos
          </a>
          <a
            href="#reportes"
            class="rounded-full border border-white/15 px-6 py-3 font-semibold text-white transition duration-300 hover:border-cyan-400 hover:bg-white/5 hover:text-cyan-400"
          >
            Ver funciones
          </a>
        </div>

        <div class="mt-10 grid max-w-lg grid-cols-3 gap-4">
          <div class="rounded-2xl border border-white/10 bg-white/5 p-4 text-center">
            <p class="text-2xl font-bold text-cyan-400">+500</p>
            <p class="mt-1 text-sm text-slate-300">Registros</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/5 p-4 text-center">
            <p class="text-2xl font-bold text-cyan-400">24/7</p>
            <p class="mt-1 text-sm text-slate-300">Disponibilidad</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/5 p-4 text-center">
            <p class="text-2xl font-bold text-cyan-400">100%</p>
            <p class="mt-1 text-sm text-slate-300">Control</p>
          </div>
        </div>
      </div>

      <div class="relative slide-right">
        <div class="absolute -inset-4 rounded-[2rem] bg-gradient-to-r from-cyan-500/20 to-blue-500/20 blur-2xl"></div>
        <div class="relative overflow-hidden rounded-[2rem] border border-white/10 bg-slate-900 p-8 shadow-2xl shadow-cyan-950/30">
          <div class="mb-6 flex items-center justify-between">
            <div>
              <p class="text-sm text-slate-400">Dashboard de almacén</p>
              <h3 class="text-2xl font-bold">Resumen general</h3>
            </div>
            <span class="rounded-full bg-cyan-400/10 px-3 py-1 text-sm text-cyan-300">
              En línea
            </span>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            {stats.map((stat) => (
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                <p class="text-sm text-slate-400">{stat.label}</p>
                <p class="mt-2 text-3xl font-bold text-cyan-400">{stat.value}</p>
              </div>
            ))}
          </div>

          <div class="mt-6 rounded-2xl border border-white/10 bg-white/5 p-4">
            <p class="text-sm text-slate-400">Estado del sistema</p>
            <div class="mt-3 h-3 overflow-hidden rounded-full bg-slate-800">
              <div class="h-full w-[78%] rounded-full bg-cyan-400"></div>
            </div>
            <p class="mt-3 text-sm text-slate-300">
              Inventario sincronizado y monitoreo activo.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section id="funciones" class="mx-auto max-w-7xl px-6 py-8">
      <div class="mb-10 fade-up">
        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-400">Funciones</p>
        <h2 class="mt-3 text-3xl font-bold md:text-4xl">Beneficios principales del sistema</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-4">
        {features.map((feature) => (
          <div class="fade-up rounded-3xl border border-white/10 bg-white/5 p-6 shadow-lg shadow-black/10 transition duration-300 hover:-translate-y-1 hover:border-cyan-400/40 hover:bg-white/[0.07]">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-cyan-400/10 text-2xl">
              {feature.icon}
            </div>
            <h3 class="mb-2 text-lg font-semibold">{feature.title}</h3>
            <p class="text-sm leading-6 text-slate-300">{feature.text}</p>
          </div>
        ))}
      </div>
    </section>

    <section id="modulos" class="mx-auto max-w-7xl px-6 py-20">
      <div class="mb-10 fade-up">
        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-400">Módulos</p>
        <h2 class="mt-3 text-3xl font-bold md:text-4xl">Componentes principales del software</h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-4">
        {modules.map((module) => (
          <div class="zoom-in group rounded-[1.75rem] border border-white/10 bg-slate-900/80 p-8 text-center transition duration-300 hover:-translate-y-1 hover:border-cyan-400/40 hover:shadow-xl hover:shadow-cyan-950/20">
            <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-cyan-400/10 text-3xl text-cyan-300">
              {module.icon}
            </div>
            <h3 class="text-xl font-semibold">{module.name}</h3>
            <p class="mt-2 text-sm text-slate-400">{module.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section id="reportes" class="mx-auto max-w-7xl px-6 py-20">
      <div class="grid gap-10 md:grid-cols-2 md:items-center">
        <div class="fade-up">
          <p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-400">Reportes</p>
          <h2 class="mt-3 text-3xl font-bold md:text-5xl">
            Información útil para decisiones más inteligentes
          </h2>
          <p class="mt-5 max-w-xl text-slate-300">
            El sistema permite visualizar reportes clave del almacén para reducir
            errores, anticipar faltantes y optimizar la administración del negocio.
          </p>
        </div>

        <div class="fade-up rounded-[2rem] border border-cyan-400/20 bg-gradient-to-r from-cyan-500/10 via-blue-500/10 to-violet-500/10 p-8">
          <ul class="space-y-4">
            {reports.map((report) => (
              <li class="rounded-2xl border border-white/10 bg-white/5 px-5 py-4 text-slate-200">
                {report}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 py-20">
      <div class="fade-up overflow-hidden rounded-[2rem] border border-cyan-400/20 bg-gradient-to-r from-cyan-500/10 via-blue-500/10 to-violet-500/10 p-10 md:p-14">
        <div class="grid gap-8 md:grid-cols-2 md:items-center">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-400">Tecnología</p>
            <h2 class="mt-3 text-3xl font-bold md:text-5xl">
              Frontend, lógica de negocio y base de datos conectados
            </h2>
            <p class="mt-4 max-w-xl text-slate-300">
              La solución integra interfaz web, backend y PostgreSQL para demostrar
              un sistema completo de gestión de almacén.
            </p>
          </div>

          <div class="flex flex-wrap gap-4">
            <span class="rounded-full border border-white/10 bg-white/5 px-4 py-2">Astro</span>
            <span class="rounded-full border border-white/10 bg-white/5 px-4 py-2">Node.js</span>
            <span class="rounded-full border border-white/10 bg-white/5 px-4 py-2">Express</span>
            <span class="rounded-full border border-white/10 bg-white/5 px-4 py-2">PostgreSQL</span>
          </div>
        </div>
      </div>
    </section>

    <section id="contacto" class="mx-auto max-w-7xl px-6 py-20">
      <div class="fade-up rounded-[2rem] border border-white/10 bg-slate-900/90 px-8 py-12 text-center shadow-xl shadow-black/10">
        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-400">Contáctanos</p>
        <h2 class="mt-3 text-3xl font-bold md:text-4xl">
          ¿Listo para conocer el sistema?
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-slate-300">
          Solicita una demo y descubre cómo una solución inteligente puede mejorar
          el control de almacén en un negocio.
        </p>

        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a
            href="#modulos"
            class="rounded-full bg-cyan-400 px-6 py-3 font-semibold text-slate-950 transition duration-300 hover:scale-105 hover:bg-cyan-300"
          >
            Ver demo
          </a>
          <a
            href="#"
            class="rounded-full border border-white/15 px-6 py-3 font-semibold text-white transition duration-300 hover:scale-105 hover:border-cyan-400 hover:text-cyan-400"
          >
            Escríbenos
          </a>
        </div>
      </div>
    </section>

    <footer class="border-t border-white/10">
      <div class="mx-auto flex max-w-7xl flex-col gap-4 px-6 py-8 text-sm text-slate-400 md:flex-row md:items-center md:justify-between">
        <p>© 2026 SmartStock. Todos los derechos reservados.</p>
        <div class="flex gap-6">
          <a href="#" class="transition hover:text-cyan-400">Instagram</a>
          <a href="#" class="transition hover:text-cyan-400">Facebook</a>
          <a href="#" class="transition hover:text-cyan-400">WhatsApp</a>
        </div>
      </div>
    </footer>
  </main>

  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("show");
          }
        });
      },
      { threshold: 0.15 }
    );

    document
      .querySelectorAll(".fade-up, .zoom-in, .slide-left, .slide-right")
      .forEach((el) => observer.observe(el));
  </script>
</Layout>