---
import Layout from "../layouts/Layout.astro";

const categories = [
  { name: "Celulares", icon: "📱", desc: "Modelos modernos y potentes" },
  { name: "Laptops", icon: "💻", desc: "Rendimiento para estudio y trabajo" },
  { name: "Audio", icon: "🎧", desc: "Sonido premium y comodidad" },
  { name: "Gaming", icon: "🎮", desc: "Accesorios para jugar mejor" },
];

const products = [
  {
    name: "Nova Phone X",
    price: "$699",
    tag: "Más vendido",
    image:
      "https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?auto=format&fit=crop&w=900&q=80",
  },
  {
    name: "AirBook Pro",
    price: "$999",
    tag: "Nuevo",
    image:
      "https://images.unsplash.com/photo-1496181133206-80ce9b88a853?auto=format&fit=crop&w=900&q=80",
  },
  {
    name: "Pulse Headphones",
    price: "$129",
    tag: "Oferta",
    image:
      "https://images.unsplash.com/photo-1505740420928-5e560c06d30e?auto=format&fit=crop&w=900&q=80",
  },
  {
    name: "Smart Watch One",
    price: "$249",
    tag: "Top",
    image:
      "https://images.unsplash.com/photo-1523275335684-37898b6baf30?auto=format&fit=crop&w=900&q=80",
  },
];

const benefits = [
  {
    title: "Envío rápido",
    text: "Recibe tus productos con seguridad y seguimiento en tiempo real.",
    icon: "🚚",
  },
  {
    title: "Pago seguro",
    text: "Métodos de pago confiables para una compra sin preocupaciones.",
    icon: "🔒",
  },
  {
    title: "Garantía real",
    text: "Todos nuestros productos cuentan con respaldo y soporte.",
    icon: "✅",
  },
  {
    title: "Atención 24/7",
    text: "Estamos listos para ayudarte antes y después de tu compra.",
    icon: "💬",
  },
];

const testimonials = [
  {
    name: "Andrea R.",
    text: "La web se ve moderna, la compra fue rápida y el producto llegó en excelente estado.",
  },
  {
    name: "Luis M.",
    text: "Me gustó la experiencia, todo está claro y los productos se ven muy bien presentados.",
  },
  {
    name: "Camila P.",
    text: "Encontré buenas ofertas y el proceso fue sencillo desde el inicio hasta el pago.",
  },
];
---

<Layout title="NovaShop | E-commerce moderno">
  <main class="min-h-screen overflow-x-hidden bg-slate-950 text-white">
    <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
      <div class="absolute left-[-120px] top-[-80px] h-72 w-72 rounded-full bg-cyan-500/20 blur-3xl"></div>
      <div class="absolute right-[-80px] top-[120px] h-80 w-80 rounded-full bg-blue-500/15 blur-3xl"></div>
      <div class="absolute bottom-[-100px] left-[30%] h-72 w-72 rounded-full bg-violet-500/10 blur-3xl"></div>
    </div>

    <header class="sticky top-0 z-50 border-b border-white/10 bg-slate-950/75 backdrop-blur-xl">
      <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
        <a href="#inicio" class="text-2xl font-black tracking-tight">
          Nova<span class="text-cyan-400">Shop</span>
        </a>

        <div class="hidden items-center gap-8 text-sm text-slate-300 md:flex">
          <a href="#inicio" class="relative transition hover:text-cyan-400 after:absolute after:left-0 after:-bottom-1 after:h-[2px] after:w-0 after:bg-cyan-400 after:transition-all after:duration-300 hover:after:w-full">Inicio</a>
          <a href="#categorias" class="relative transition hover:text-cyan-400 after:absolute after:left-0 after:-bottom-1 after:h-[2px] after:w-0 after:bg-cyan-400 after:transition-all after:duration-300 hover:after:w-full">Categorías</a>
          <a href="#productos" class="relative transition hover:text-cyan-400 after:absolute after:left-0 after:-bottom-1 after:h-[2px] after:w-0 after:bg-cyan-400 after:transition-all after:duration-300 hover:after:w-full">Productos</a>
          <a href="#testimonios" class="relative transition hover:text-cyan-400 after:absolute after:left-0 after:-bottom-1 after:h-[2px] after:w-0 after:bg-cyan-400 after:transition-all after:duration-300 hover:after:w-full">Opiniones</a>
          <a href="#contacto" class="relative transition hover:text-cyan-400 after:absolute after:left-0 after:-bottom-1 after:h-[2px] after:w-0 after:bg-cyan-400 after:transition-all after:duration-300 hover:after:w-full">Contacto</a>
        </div>

        <div class="flex items-center gap-3">
          <button class="hidden rounded-full border border-white/15 px-4 py-2 text-sm text-slate-200 transition hover:border-cyan-400 hover:text-cyan-400 sm:block">
            Iniciar sesión
          </button>
          <button class="rounded-full bg-cyan-400 px-4 py-2 text-sm font-semibold text-slate-950 shadow-lg shadow-cyan-500/20 transition duration-300 hover:scale-105 hover:bg-cyan-300">
            Carrito
          </button>
        </div>
      </nav>
    </header>

    <section
      id="inicio"
      class="mx-auto grid max-w-7xl gap-14 px-6 py-20 md:grid-cols-2 md:items-center md:py-28"
    >
      <div class="slide-left">
        <span class="inline-flex rounded-full border border-cyan-400/30 bg-cyan-400/10 px-4 py-1 text-sm text-cyan-300">
          Tienda online premium
        </span>

        <h1 class="mt-6 max-w-2xl text-5xl font-black leading-tight md:text-6xl">
          Compra tecnología con
          <span class="bg-gradient-to-r from-cyan-400 to-blue-400 bg-clip-text text-transparent">
            estilo, confianza y seguridad
          </span>
        </h1>

        <p class="mt-6 max-w-xl text-lg leading-8 text-slate-300">
          Descubre productos de calidad, promociones exclusivas y una experiencia
          de compra moderna pensada para quienes buscan innovación y rendimiento.
        </p>

        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="#productos"
            class="rounded-full bg-cyan-400 px-6 py-3 font-semibold text-slate-950 shadow-lg shadow-cyan-500/20 transition duration-300 hover:scale-105 hover:bg-cyan-300"
          >
            Comprar ahora
          </a>
          <a
            href="#categorias"
            class="rounded-full border border-white/15 px-6 py-3 font-semibold text-white transition duration-300 hover:border-cyan-400 hover:bg-white/5 hover:text-cyan-400"
          >
            Ver catálogo
          </a>
        </div>

        <div class="mt-10 grid max-w-lg grid-cols-3 gap-4">
          <div class="rounded-2xl border border-white/10 bg-white/5 p-4 text-center">
            <p class="text-2xl font-bold text-cyan-400">+5K</p>
            <p class="mt-1 text-sm text-slate-300">Clientes felices</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/5 p-4 text-center">
            <p class="text-2xl font-bold text-cyan-400">+200</p>
            <p class="mt-1 text-sm text-slate-300">Productos</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/5 p-4 text-center">
            <p class="text-2xl font-bold text-cyan-400">24/7</p>
            <p class="mt-1 text-sm text-slate-300">Soporte</p>
          </div>
        </div>
      </div>

      <div class="relative slide-right">
        <div class="absolute -inset-4 rounded-[2rem] bg-gradient-to-r from-cyan-500/20 to-blue-500/20 blur-2xl"></div>
        <div class="relative overflow-hidden rounded-[2rem] border border-white/10 bg-slate-900 shadow-2xl shadow-cyan-950/30">
          <img
            src="https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da?auto=format&fit=crop&w=1400&q=80"
            alt="Tienda online moderna"
            class="h-full w-full object-cover"
          />
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 py-8">
      <div class="grid gap-6 md:grid-cols-4">
        {benefits.map((benefit) => (
          <div class="fade-up rounded-3xl border border-white/10 bg-white/5 p-6 shadow-lg shadow-black/10 transition duration-300 hover:-translate-y-1 hover:border-cyan-400/40 hover:bg-white/[0.07]">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-cyan-400/10 text-2xl">
              {benefit.icon}
            </div>
            <h3 class="mb-2 text-lg font-semibold">{benefit.title}</h3>
            <p class="text-sm leading-6 text-slate-300">{benefit.text}</p>
          </div>
        ))}
      </div>
    </section>

    <section id="categorias" class="mx-auto max-w-7xl px-6 py-20">
      <div class="mb-10 fade-up">
        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-400">Categorías</p>
        <h2 class="mt-3 text-3xl font-bold md:text-4xl">Explora lo mejor de nuestra tienda</h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-4">
        {categories.map((category) => (
          <div class="zoom-in group rounded-[1.75rem] border border-white/10 bg-slate-900/80 p-8 text-center transition duration-300 hover:-translate-y-1 hover:border-cyan-400/40 hover:shadow-xl hover:shadow-cyan-950/20">
            <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-cyan-400/10 text-3xl text-cyan-300">
              {category.icon}
            </div>
            <h3 class="text-xl font-semibold">{category.name}</h3>
            <p class="mt-2 text-sm text-slate-400">{category.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section id="productos" class="mx-auto max-w-7xl px-6 py-20">
      <div class="mb-10 flex items-end justify-between gap-4 fade-up">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-400">Destacados</p>
          <h2 class="mt-3 text-3xl font-bold md:text-4xl">Productos populares</h2>
        </div>
        <a href="#" class="text-sm font-medium text-cyan-400 transition hover:text-cyan-300">
          Ver todos
        </a>
      </div>

      <div class="grid gap-8 sm:grid-cols-2 xl:grid-cols-4">
        {products.map((product) => (
          <article class="fade-up group overflow-hidden rounded-[1.75rem] border border-white/10 bg-slate-900 transition duration-300 hover:-translate-y-1 hover:border-cyan-400/40 hover:shadow-2xl hover:shadow-cyan-950/20">
            <div class="relative overflow-hidden">
              <img
                src={product.image}
                alt={product.name}
                class="h-64 w-full object-cover transition duration-500 group-hover:scale-105"
              />
              <span class="absolute left-4 top-4 rounded-full bg-cyan-400 px-3 py-1 text-xs font-semibold text-slate-950">
                {product.tag}
              </span>
            </div>

            <div class="p-6">
              <h3 class="text-xl font-semibold">{product.name}</h3>
              <p class="mt-2 text-sm leading-6 text-slate-400">
                Diseño moderno, calidad premium y rendimiento ideal para tu día a día.
              </p>

              <div class="mt-5 flex items-center justify-between">
                <span class="text-2xl font-bold text-cyan-400">{product.price}</span>
                <button class="rounded-full bg-cyan-400 px-4 py-2 text-sm font-semibold text-slate-950 transition duration-300 hover:scale-105 hover:bg-cyan-300">
                  Agregar
                </button>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 py-20">
      <div class="fade-up overflow-hidden rounded-[2rem] border border-cyan-400/20 bg-gradient-to-r from-cyan-500/10 via-blue-500/10 to-violet-500/10 p-10 md:p-14">
        <div class="grid gap-8 md:grid-cols-2 md:items-center">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-400">Oferta especial</p>
            <h2 class="mt-3 text-3xl font-bold md:text-5xl">
              Hasta 30% de descuento en accesorios
            </h2>
            <p class="mt-4 max-w-xl text-slate-300">
              Aprovecha nuestras promociones exclusivas por tiempo limitado y compra
              con la mejor combinación de calidad y precio.
            </p>
          </div>

          <div class="flex justify-start md:justify-end">
            <a
              href="#productos"
              class="rounded-full bg-cyan-400 px-8 py-4 font-semibold text-slate-950 shadow-lg shadow-cyan-500/20 transition duration-300 hover:scale-105 hover:bg-cyan-300"
            >
              Comprar oferta
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="testimonios" class="mx-auto max-w-7xl px-6 py-20">
      <div class="mb-10 fade-up">
        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-400">Opiniones</p>
        <h2 class="mt-3 text-3xl font-bold md:text-4xl">Lo que dicen nuestros clientes</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {testimonials.map((testimonial) => (
          <div class="zoom-in rounded-[1.75rem] border border-white/10 bg-white/5 p-6 transition duration-300 hover:border-cyan-400/30 hover:bg-white/[0.07]">
            <div class="mb-4 text-cyan-400">★★★★★</div>
            <p class="leading-7 text-slate-300">“{testimonial.text}”</p>
            <p class="mt-5 font-semibold text-white">{testimonial.name}</p>
          </div>
        ))}
      </div>
    </section>

    <section id="contacto" class="mx-auto max-w-7xl px-6 py-20">
      <div class="fade-up rounded-[2rem] border border-white/10 bg-slate-900/90 px-8 py-12 text-center shadow-xl shadow-black/10">
        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-400">Contáctanos</p>
        <h2 class="mt-3 text-3xl font-bold md:text-4xl">
          ¿Listo para comprar con confianza?
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-slate-300">
          Únete a una tienda moderna que ofrece rapidez, seguridad y una experiencia
          premium en cada compra.
        </p>

        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a
            href="#productos"
            class="rounded-full bg-cyan-400 px-6 py-3 font-semibold text-slate-950 transition duration-300 hover:scale-105 hover:bg-cyan-300"
          >
            Comprar ahora
          </a>
          <a
            href="#"
            class="rounded-full border border-white/15 px-6 py-3 font-semibold text-white transition duration-300 hover:scale-105 hover:border-cyan-400 hover:text-cyan-400"
          >
            Escríbenos
          </a>
        </div>
      </div>
    </section>

    <footer class="border-t border-white/10">
      <div class="mx-auto flex max-w-7xl flex-col gap-4 px-6 py-8 text-sm text-slate-400 md:flex-row md:items-center md:justify-between">
        <p>© 2026 NovaShop. Todos los derechos reservados.</p>
        <div class="flex gap-6">
          <a href="#" class="transition hover:text-cyan-400">Instagram</a>
          <a href="#" class="transition hover:text-cyan-400">Facebook</a>
          <a href="#" class="transition hover:text-cyan-400">WhatsApp</a>
        </div>
      </div>
    </footer>
  </main>

  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("show");
          }
        });
      },
      { threshold: 0.15 }
    );

    document
      .querySelectorAll(".fade-up, .zoom-in, .slide-left, .slide-right")
      .forEach((el) => {
        observer.observe(el);
      });
  </script>
</Layout>